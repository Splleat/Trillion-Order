@hostname = localhost:10407


### 주문 생성 (회원)
POST http://{{hostname}}/orders
Content-Type: application/json
X-Member-Id: 1
X-Member-Role: MEMBER

{
  "ordererName": "홍길동",
  "ordererContact": "010-1234-5678",
  "deliveryDate": "2026-07-15T10:00:00",

  "receiverName": "김철수",
  "receiverContact": "010-9876-5432",
  "receiverAddress": "광주광역시 동구 제봉로 92 (대성학원)",
  "receiverPostCode": "61455",

  "nonMemberPassword": null,

  "pointUsage": 1000,
  "couponId": 1,

  "orderItems": [
    {
      "bookId": 1,
      "quantity": 2,
      "packagingId": 2
    },
    {
      "bookId": 2,
      "quantity": 2,
      "packagingId": 1
    }
  ]
}

### 주문 생성 (비회원)
POST http://{{hostname}}/orders
Content-Type: application/json
X-Guest-Id: GUEST
X-Member-Role: GUEST

{
  "ordererName": "이영희",
  "ordererContact": "010-2222-3333",
  "deliveryDate": "2028-07-15T14:00:00",

  "receiverName": "박민수",
  "receiverContact": "010-4444-5555",
  "receiverAddress": "서울특별시 강남구 테헤란로 123 (삼성동)",
  "receiverPostCode": "06134",

  "nonMemberPassword": "1234",

  "pointUsage": 0,
  "couponId": null,

  "orderItems": [
    {
      "bookId": 3,
      "quantity": 1,
      "packagingId": 3
    }
  ]
}

### 주문 목록 조회 (관리자)
GET http://{{hostname}}/orders/admin
X-Member-Id: 2
X-Member-Role: ADMIN

### 주문 목록 조회 (회원)
GET http://{{hostname}}/orders
X-Member-Id: 1
X-Member-Role: MEMBER

### 주문 단건 조회 (회원)
GET http://{{hostname}}/orders/1
X-Member-Id: 1
X-Member-Role: MEMBER

### 주문 단건 조회 (비회원)
POST http://{{hostname}}/orders/non-members/
Content-Type: application/json
X-Guest-Id: GUEST
X-Member-Role: GUEST

{
  "orderNumber": "ORD-SAMPLE-002",
  "nonMemberPassword": "1234"
}

### 주문 상품 상태 변경: 주문 취소 (회원)
DELETE http://{{hostname}}/orders/1
Content-Type: application/json
X-Member-Id: 1
X-Member-Role: MEMBER

{
  "status": "CANCELED"
}

### 주문 상품 상태 변경: 주문 취소 (비회원)
DELETE http://{{hostname}}/orders/non-members/1
Content-Type: application/json
X-Guest-Id: GUEST
X-Member-Role: GUEST

{
    "status": "CANCELED",
    "nonMemberPassword": "1234"
}

### 주문 상품 상태 변경: 배송 중 (관리자)
PATCH http://{{hostname}}/orders/1/items/1
X-Member-Id: 1
X-Member-Role: ADMIN
Content-Type: application/json

{
  "status": "SHIPPED"
}

### 주문 상품 상태 변경: 배송 완료 (관리자)
PATCH http://{{hostname}}/orders/1/items/1
X-Member-Id: 1
X-Member-Role: ADMIN
Content-Type: application/json

{
  "status": "DELIVERED"
}

### 주문 상품 상태 변경: 반품 요청 (단순 변심) (회원)
PATCH http://{{hostname}}/orders/1/items/1
X-Member-Id: 1
X-Member-Role: MEMBER
Content-Type: application/json

{
  "status": "RETURN_REQUESTED_CHANGE_OF_MIND"
}

### 주문 상품 상태 변경: 반품 완료 (관리자)
PATCH http://{{hostname}}/orders/1/items/1
X-Member-Id: 1
X-Member-Role: ADMIN
Content-Type: application/json

{
  "status": "RETURNED"
}

### 주문 상품 상태 변경: 구매 확정 (회원)
PATCH http://{{hostname}}/orders/1/items/1
X-Member-Id: 1
X-Member-Role: MEMBER
Content-Type: application/json

{
  "status": "CONFIRMED"
}

### 주문 상품 상태 변경: 반품 요청 (비회원)
PATCH http://{{hostname}}/orders/non-members/1/items/1
Content-Type: application/json
X-Guest-Id: GUEST
X-Member-Role: GUEST

{
  "nonMemberPassword": "1234",
  "status": "RETURN_REQUESTED_CHANGE_OF_MIND"
}